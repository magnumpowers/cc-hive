#!/bin/bash

# Hive desktop launcher
# Starts the Next.js server and opens it in the default browser

PORT=3333
LOCKFILE="/tmp/hive-launcher.lock"

# Prevent multiple simultaneous launches
if [ -f "$LOCKFILE" ]; then
  LOCK_PID=$(cat "$LOCKFILE" 2>/dev/null)
  if [ -n "$LOCK_PID" ] && kill -0 "$LOCK_PID" 2>/dev/null; then
    # Another launch is in progress — just open the browser and exit
    open "http://localhost:$PORT"
    exit 0
  fi
  # Stale lock file — remove it
  rm -f "$LOCKFILE"
fi
echo $$ > "$LOCKFILE"
trap "rm -f '$LOCKFILE'" EXIT

# If the server is already running, just open the browser
if curl -s --max-time 2 "http://localhost:$PORT" > /dev/null 2>&1; then
  open "http://localhost:$PORT"
  exit 0
fi

# Find the Hive project directory
# 1. Check if CCHIVE_DIR is set
# 2. Check common locations
# 3. Check relative to the app bundle (dev mode)
if [ -n "$CCHIVE_DIR" ] && [ -d "$CCHIVE_DIR" ]; then
  HIVE_DIR="$CCHIVE_DIR"
elif [ -f "$HOME/.hive-path" ]; then
  HIVE_DIR="$(cat "$HOME/.hive-path")"
elif [ -f "$HOME/.cc-hive-path" ]; then
  HIVE_DIR="$(cat "$HOME/.cc-hive-path")"
elif [ -d "$HOME/cc-hive" ]; then
  HIVE_DIR="$HOME/cc-hive"
elif [ -d "$HOME/hive" ] && [ -f "$HOME/hive/package.json" ]; then
  HIVE_DIR="$HOME/hive"
else
  # Try relative to app bundle (works when app is inside the project)
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  CANDIDATE="$(cd "$SCRIPT_DIR/../../.." 2>/dev/null && pwd)"
  if [ -f "$CANDIDATE/package.json" ] && grep -q '"hive"\|cc-hive' "$CANDIDATE/package.json" 2>/dev/null; then
    HIVE_DIR="$CANDIDATE"
  else
    osascript -e 'display alert "Hive" message "Could not find the Hive project directory. Create ~/.hive-path with the path to your Hive installation." as critical'
    exit 1
  fi
fi

# Find node
export PATH="/usr/local/bin:/opt/homebrew/bin:$HOME/.nvm/versions/node/$(ls "$HOME/.nvm/versions/node/" 2>/dev/null | tail -1)/bin:$PATH"

if ! command -v node &> /dev/null; then
  osascript -e 'display alert "Hive" message "Node.js is required but not found. Install it from nodejs.org" as critical'
  exit 1
fi

cd "$HIVE_DIR" || exit 1

# Install deps if needed
if [ ! -d "node_modules" ]; then
  npm install 2>&1
fi

# Build if needed
if [ ! -d ".next" ]; then
  osascript -e 'display notification "Building Hive for first run..." with title "Hive"'
  npm run build 2>&1
fi

# Start server in background
npx next start -p $PORT &
SERVER_PID=$!

# Clean up both lockfile and server on exit
trap "kill $SERVER_PID 2>/dev/null; rm -f '$LOCKFILE'" EXIT

# Wait for server to be ready
for i in $(seq 1 30); do
  if curl -s --max-time 2 "http://localhost:$PORT" > /dev/null 2>&1; then
    break
  fi
  # If the server process died, bail out
  if ! kill -0 "$SERVER_PID" 2>/dev/null; then
    osascript -e 'display alert "Hive" message "Server failed to start. Check that port 3333 is not in use." as critical'
    exit 1
  fi
  sleep 0.5
done

# Open in browser
open "http://localhost:$PORT"

wait $SERVER_PID
